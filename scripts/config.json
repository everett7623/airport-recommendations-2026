{
  "source": {
    "url": "https://www.vpsknow.com/airport-recommendations",
    "fallbackUrl": "https://raw.githubusercontent.com/everett7623/VPS-Knowledge/main/src/pages/airport-recommendations.astro"
  },
  "selectors": {
    "categories": {
      "container": "section[data-category], .category-section, section:has(h2)",
      "title": "h2, .category-title",
      "description": ".category-description, .category-desc",
      "airportList": ".airport-list, .airport-card, table tr, .grid > *"
    },
    "airport": {
      "name": "[data-name], .airport-name, h3, td:first-child strong",
      "url": "a[href*='s.y8o.de'], a[href*='airport'], .airport-link",
      "lineType": "[data-line], .line-type, .line",
      "pricing": "[data-price], .pricing, .price",
      "coupon": "[data-coupon], .coupon, .coupon-code",
      "features": "[data-features], .features li, .tag-list span",
      "description": "[data-desc], .description, .desc, p",
      "tags": "[data-tags], .tags span, .tag"
    }
  },
  "output": {
    "jsonPath": "./data/airports.json",
    "readmePath": "./README.md",
    "readmeSimplePath": "./README-SIMPLE.md",
    "backupOld": true
  }
}
